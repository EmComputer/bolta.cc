---
import BaseLayout from '../../layouts/baselayout.astro';
import ar from '../../i18n/ar.json';
---

<BaseLayout title={ar.aboutUs} lang="ar">
  <section class="about-container">
    <div class="about-content">
      <h1>{ar.aboutTitle}</h1>
      <p>{ar.aboutDesc1}</p>
      
      <div class="mission-grid">
        <div class="mission-item">
          <h3>{ar.missionTitle}</h3>
          <p>{ar.missionDesc}</p>
        </div>
        <div class="mission-item">
          <h3>{ar.locationTitle}</h3>
          <p>{ar.location}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>