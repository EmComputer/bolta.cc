---
import '../styles/style.css';
import en from '../i18n/en.json';
import ar from '../i18n/ar.json';

const { title, lang = "en" } = Astro.props;
const t = lang === "ar" ? ar : en;
---
<!DOCTYPE html>
<html lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'}>
    
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Bolta.cc</title>
    <script is:inline>
        (function() {
            const savedLang = localStorage.getItem('preferredLanguage');
            const path = window.location.pathname;
            if (savedLang === 'ar' && !path.startsWith('/ar')) {
                window.location.href = '/ar' + path;
            } else if (savedLang === 'en' && path.startsWith('/ar')) {
                window.location.href = path.replace('/ar', '') || '/';
            }
        })();
    </script>
</head>
<body class={lang === 'ar' ? 'rtl' : ''}>
    <header>
        <nav>
            <a href="/" class="logo-link">
                <div class="logo">Bolta<span>.cc</span></div>
            </a>
            <div class="search-container">
                <div class="search-bar">
                    <input type="text" placeholder={t.searchPlaceholder}>
                    <button type="submit">
                        <img src="/images/search-icon.png" alt="Search" width="20">
                    </button>
                </div>
            </div>
            <div class="nav-actions">
                <div class="action-item lang-dropdown">
                    <span class="top-label">{t.langLabel}</span>
                    <div class="bottom-row">
                        <span class="main-text">{lang === 'en' ? 'English' : 'العربية'}</span>
                        <span class="arrow">⌄</span>
                    </div>
                    <div class="dropdown-menu">
                        <a href="#" class="dropdown-link" onclick="setLanguage('en')">English</a>
                        <a href="#" class="dropdown-link" onclick="setLanguage('ar')">العربية</a>
                    </div>
                </div>
                <div class="divider"></div>
                <div class="action-item disabled">
                    <span class="top-label">{t.accountLabel}</span>
                    <span class="main-text">{t.accountMain}</span>
                </div>
                <div class="divider"></div>
                <div class="action-item cart-item disabled">
                    <div class="cart-icon-wrapper">
                        <img src="/images/cart-icon.png" alt="Cart" width="26">
                        <span class="cart-badge">0</span>
                    </div>
                    <span class="main-text">{t.cartMain}</span>
                </div>
            </div>
        </nav>
    </header>

    <main><slot /></main>

    <footer class="main-footer">
    <div class="footer-content">
        <!-- Existing Brand Column -->
        <div class="footer-column brand-col">
            <div class="logo small-logo">Bolta<span>.cc</span></div>
            <p>{t.footerDesc}</p>
        </div>

        <!-- NEW Join Us Column -->
        <div class="footer-column">
            <h4>{t.joinUs}</h4>
            <ul>
                <li><a href="/driver">{t.driver}</a></li>
                <li><a href="/seller">{t.seller}</a></li>
            </ul>
        </div>

        <!-- Existing Contact Column -->
        <div class="footer-column">
            <h4>{t.contactUs}</h4>
            <ul>
                <li>support@bolta.cc</li>
                <li>{t.location}</li>
            </ul>
        </div>

        <!-- Existing Links Column -->
        <div class="footer-column">
            <h4>{t.quickLinks}</h4>
            <ul class="horizontal-links">
                <li><a href="/about">{t.aboutUs}</a></li>
                <li><a href="#">{t.privacyPolicy}</a></li>
                <li><a href="/tos">{t.terms}</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2026 Bolta.cc</p>
    </div>
    </footer>
    <script src="../scripts/script.js"></script>
</body>
</html>